{
  "name": "pi-agents",
  "version": "1.0.0",
  "description": "Agent layer specification for pi — composable, self-enhancing AI agents",
  "keywords": [
    "pi-package",
    "agents",
    "ai"
  ],
  "license": "MIT",
  "author": "josorio7122",
  "repository": "github:josorio7122/pi-agents",
  "type": "module",
  "exports": {
    ".": "./src/api.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "PI_E2E=1 vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "lint:blanks": "bash scripts/check-blank-lines.sh",
    "check": "npm run lint && npm run lint:blanks && npm run typecheck && npm run test",
    "format": "biome format --write src/",
    "simulate": "tsx scripts/simulate-ui.ts",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*",
    "@types/node": "^25.5.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "themes": [
      "./themes"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "themes",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "biome check --fix --no-errors-on-unmatched"
    ]
  }
}
